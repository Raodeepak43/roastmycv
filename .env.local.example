ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_GAALI_MODEL=claude-sonnet-4-6
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Supabase — server only (Vercel → Settings → Environment Variables)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_jwt_here

# User auth (login + Google OAuth) — anon key is safe for the browser; never use service role here
SUPABASE_ANON_KEY=your_anon_key_here
# Or use NEXT_PUBLIC_* names directly:
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Admin dashboard (/admin) — set a strong password
ADMIN_PASSWORD=your_secure_admin_password_here
NEXT_PUBLIC_UPI_ID=yourname@upi
NEXT_PUBLIC_UPI_NAME=Your Name
# Optional: static QR image instead of auto-generated (e.g. /upi-qr.png)
# NEXT_PUBLIC_UPI_QR=/upi-qr.png
