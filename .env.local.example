ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_GAALI_MODEL=claude-sonnet-4-6

# ElevenLabs — Mock Interview voice (https://elevenlabs.io)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Optional overrides (default voice: George — calm British interviewer)
# ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Sarvam AI — Hinglish roasts only (https://dashboard.sarvam.ai)
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_KEY=your_sarvam_api_key_here
SARVAM_MODEL=sarvam-30b

NEXT_PUBLIC_GA_ID=G-XS1LMJZ63K

# Public support email (shown on contact, privacy, billing pages)
NEXT_PUBLIC_SUPPORT_EMAIL=support@mycvroast.in

# Supabase — server only (Vercel → Settings → Environment Variables)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_jwt_here

# User auth (login + Google OAuth) — anon key is safe for the browser; never use service role here
SUPABASE_ANON_KEY=your_anon_key_here

# Canonical site URL for OAuth redirects and SEO (use www primary domain)
NEXT_PUBLIC_SITE_URL=https://www.mycvroast.in
# User dashboard subdomain (same Vercel project — add domain in Vercel → Domains)
NEXT_PUBLIC_DASHBOARD_URL=https://dashboard.mycvroast.in
NEXT_PUBLIC_DASHBOARD_HOST=dashboard.mycvroast.in
# Supabase Dashboard → Authentication → URL Configuration:
#   Site URL: https://www.mycvroast.in
#   Redirect URLs:
#     https://www.mycvroast.in/auth/callback
#     https://www.mycvroast.in/login/update-password
#     https://dashboard.mycvroast.in/auth/callback
#     https://mycvroast.in/auth/callback
#     http://localhost:3000/auth/callback

# Google OAuth Client ID (same as Supabase Google provider — public, safe in browser)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
# In Google Cloud → Credentials → Web client, also add Authorized JavaScript origins:
#   http://localhost:3000
#   https://www.mycvroast.in
#   https://dashboard.mycvroast.in
#   https://mycvroast.in
# Redirect URI stays: https://YOUR_PROJECT.supabase.co/auth/v1/callback

# Admin dashboard — bcrypt hash (recommended) or legacy plain password
# Generate hash: node scripts/hash-admin-password.mjs "your-password"
ADMIN_PASSWORD_BCRYPT=
# Legacy fallback only — remove after setting ADMIN_PASSWORD_BCRYPT above
ADMIN_PASSWORD=your_secure_admin_password_here
# Secret path only you bookmark — 12+ chars, lowercase letters/numbers/hyphens
# Example: https://www.mycvroast.in/manage-k9x2p7v4m8q
ADMIN_LOGIN_PATH=/manage-k9x2p7v4m8q

# Careerjet — job search portal (https://www.careerjet.com/partners)
# API key via HTTP Basic Auth (username = key, password empty). Whitelist server IP in partner dashboard.
CAREERJET_API_KEY=your_careerjet_api_key_here

# Razorpay — Pro paywall (https://dashboard.razorpay.com/app/keys)
# Key ID is public (checkout); secret stays server-only
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
